{
  "realm": "platform",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": false,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "roles": {
    "realm": [
      {
        "name": "personnel.files.read.self",
        "description": "Yalnız kendi personel dosyalarını okur"
      },
      {
        "name": "personnel.files.read.team",
        "description": "Kendi + yönettiği ekibin personel dosyalarını okur"
      },
      {
        "name": "personnel.files.read.all",
        "description": "Tüm personel dosyalarını okur"
      },
      {
        "name": "personnel.files.write.self",
        "description": "Kendi personel dosyalarını yükler/arşivler"
      },
      {
        "name": "personnel.files.write.all",
        "description": "Tüm personel dosyalarını yükler/arşivler"
      },
      {
        "name": "ops.read",
        "description": "Ops console okuma erişimi"
      },
      {
        "name": "ops.admin",
        "description": "Ops console tam erişim — backup/restore tetikleme"
      },
      {
        "name": "ops.execute",
        "description": "Ops güvenli write — backup tetikleme, servis restart"
      }
    ]
  },
  "clients": [
    {
      "clientId": "yonetimapi",
      "name": "YonetimApi Service Account",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "yonetimapi-secret-v1",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "publicClient": false,
      "bearerOnly": false,
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "app_code",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.value": "yonetimapi",
            "userinfo.token.claim": "false",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "app_code",
            "access.tokenResponse.claim": "false",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "filoapi",
      "name": "FiloApi Service Account",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "filoapi-secret",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "publicClient": false,
      "bearerOnly": false,
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "app_code",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.value": "filoapi",
            "userinfo.token.claim": "false",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "app_code",
            "access.tokenResponse.claim": "false",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "frontend-test",
      "name": "Frontend Test Client (password grant icin)",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "personnel_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "personnel_id",
            "userinfo.token.claim": "false",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "personnel_id",
            "jsonType.label": "String"
          }
        },
        {
          "name": "vehicle_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "vehicle_id",
            "userinfo.token.claim": "false",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "vehicle_id",
            "jsonType.label": "String"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "false",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "roles",
            "multivalued": "true",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
