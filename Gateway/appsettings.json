{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "yonetimapi-root-route": {
        "ClusterId": "yonetimapi-cluster",
        "Match": {
          "Path": "/api/personnel"
        }
      },
      "yonetimapi-route": {
        "ClusterId": "yonetimapi-cluster",
        "Match": {
          "Path": "/api/personnel/{**catch-all}"
        }
      },
      "flotaapi-root-route": {
        "ClusterId": "flotaapi-cluster",
        "Match": {
          "Path": "/api/vehicles"
        }
      },
      "flotaapi-route": {
        "ClusterId": "flotaapi-cluster",
        "Match": {
          "Path": "/api/vehicles/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "yonetimapi-cluster": {
        "Destinations": {
          "yonetimapi": {
            "Address": "http://localhost:5076/"
          }
        }
      },
      "flotaapi-cluster": {
        "Destinations": {
          "flotaapi": {
            "Address": "http://localhost:5077/"
          }
        }
      }
    }
  }
}
